# Cloudflare Pages response headers — ported from the old Apache .htaccess.
# (HTTPS is enforced by Cloudflare, so the mod_rewrite redirect is not needed.)

# Security headers on every response. HSTS only takes effect once a response is
# already served over HTTPS; no `preload` so HTTPS can still be disabled later.
#
# The CSP is the page's "no telemetry" promise made browser-enforceable:
# default-src 'none' inherits to connect-src, font-src, media-src, worker-src
# and manifest-src, so fetch/XHR/beacons/WebSockets, web fonts and CDNs are all
# impossible — any visitor can verify the claim in one DevTools glance.
# 'unsafe-inline' is deliberate and required: the page is a single file whose
# CSS and JS are inline. A hash-based policy would silently break the page on
# every hand edit, and there is no build step to regenerate hashes.
# No report-uri/report-to — that would phone home.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=(), browsing-topics=()

# HTML must revalidate on every request so deploys are visible immediately.
/
  Cache-Control: no-cache, must-revalidate
/*.html
  Cache-Control: no-cache, must-revalidate

# Images and the favicon change rarely and may cache for a day. Filenames are
# not content-hashed, so a day is the honest ceiling — rename to bust.
/assets/*
  Cache-Control: public, max-age=86400
/favicon.svg
  Cache-Control: public, max-age=86400

# The social card carries a version in its name, which is what earns a long TTL.
/assets/og-card-v1.jpg
  Cache-Control: public, max-age=31536000, immutable
