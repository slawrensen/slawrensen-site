# Force HTTPS for all requests.
#
# SiteGround terminates TLS at its edge proxy and forwards to Apache over http,
# so %{HTTPS} alone reads "off" even on secure requests. Checking the forwarded
# protocol (X-Forwarded-Proto) as well prevents a redirect loop: a request that
# arrived over https carries X-Forwarded-Proto: https and is left alone.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# Security headers (defense in depth). `always` so they apply to every response;
# HSTS only takes effect once a response is already served over HTTPS. No
# `preload` so HTTPS can still be disabled later if ever needed.
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache policy. Without an upstream policy the SiteGround proxy cached the
# HTML on its own long TTL and served deploys stale. HTML must revalidate
# every request; images and the favicon may cache for a day (they change
# rarely, and a redeploy that matters can rename them).
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
    # SiteGround's NGINX dynamic cache ignores origin Cache-Control when
    # deciding what to store, but it never caches a response that sets a
    # cookie and never serves cached content to a request carrying one.
    # This inert first-party cookie therefore keeps HTML permanently out of
    # the proxy cache, so deploys surface without a Site Tools flush.
    # Images below keep caching normally.
    Header always set Set-Cookie "sg_nocache=1; Path=/; Max-Age=60; SameSite=Lax"
  </FilesMatch>
  <FilesMatch "\.(png|svg|jpg|webp|ico)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>
